        }))
    }

    /// Build hierarchical function tree
    fn build_function_tree(&self, functions: Vec<FunctionInfo>, group_by: &str) -> Result<Vec<Value>> {
        match group_by {
            "file" => self.group_by_file(functions),
            "complexity" => self.group_by_complexity(functions),
            "class" => self.group_by_class(functions),
            _ => self.group_by_file(functions),
        }
    }

    /// Group functions by file
    fn group_by_file(&self, functions: Vec<FunctionInfo>) -> Result<Vec<Value>> {
        let mut file_groups: HashMap<String, Vec<&FunctionInfo>> = HashMap::new();
        
        for func in &functions {
            file_groups.entry(func.file_path.clone())
                .or_insert_with(Vec::new)
                .push(func);
        }

        let mut tree = Vec::new();
        for (file_path, file_functions) in file_groups {
            let file_name = std::path::Path::new(&file_path)
                .file_name()
                .and_then(|n| n.to_str())
                .unwrap_or(&file_path);

            let avg_complexity: f64 = file_functions.iter()
                .map(|f| f.complexity.unwrap_or(0) as f64)
                .sum::<f64>() / file_functions.len() as f64;

            let children: Vec<Value> = file_functions.iter()
                .map(|f| json!({
                    "type": "function",
                    "label": f.name,
                    "signature": f.signature,
                    "startLine": f.start_line,
                    "endLine": f.end_line,
                    "language": f.language,
                    "complexity": f.complexity,
                    "isHighComplexity": f.complexity.unwrap_or(0) > 10,
                    "lineCount": f.end_line.saturating_sub(f.start_line) + 1
                }))
                .collect();

            tree.push(json!({
                "type": "file",
                "label": file_name,
                "path": file_path,
                "functionCount": file_functions.len(),
                "avgComplexity": (avg_complexity * 10.0).round() / 10.0,
                "hasHighComplexity": file_functions.iter().any(|f| f.complexity.unwrap_or(0) > 10),
                "children": children
            }));
        }

        // Sort by function count descending
        tree.sort_by(|a, b| {
            b["functionCount"].as_u64().unwrap_or(0)
                .cmp(&a["functionCount"].as_u64().unwrap_or(0))
        });

        Ok(tree)
    }

    /// Group functions by complexity
    fn group_by_complexity(&self, functions: Vec<FunctionInfo>) -> Result<Vec<Value>> {
        let mut complexity_groups: HashMap<String, Vec<&FunctionInfo>> = HashMap::new();
        
        for func in &functions {
            let complexity_level = match func.complexity.unwrap_or(0) {
                0..=3 => "Low (0-3)",
                4..=7 => "Medium (4-7)",
                8..=15 => "High (8-15)",
                _ => "Critical (16+)",
            };
            
            complexity_groups.entry(complexity_level.to_string())
                .or_insert_with(Vec::new)
                .push(func);
        }

        let mut tree = Vec::new();
        let complexity_order = ["Critical (16+)", "High (8-15)", "Medium (4-7)", "Low (0-3)"];
        
        for level in complexity_order.iter() {
            if let Some(level_functions) = complexity_groups.get(*level) {
                let children: Vec<Value> = level_functions.iter()
                    .map(|f| json!({
                        "type": "function",
                        "label": f.name,
                        "signature": f.signature,
                        "file": std::path::Path::new(&f.file_path).file_name()
                            .and_then(|n| n.to_str()).unwrap_or(&f.file_path),
                        "startLine": f.start_line,
                        "complexity": f.complexity
                    }))
                    .collect();

                tree.push(json!({
                    "type": "complexity_group",
                    "label": level,
                    "functionCount": level_functions.len(),
                    "children": children
                }));
            }
        }

        Ok(tree)
    }

    /// Group functions by class (simplified)
    fn group_by_class(&self, functions: Vec<FunctionInfo>) -> Result<Vec<Value>> {
        // For now, just group by file - class extraction would need more sophisticated analysis
        self.group_by_file(functions)
    }

    /// Count functions in tree node
    fn count_functions_in_node(&self, node: &Value) -> usize {
        if let Some(children) = node["children"].as_array() {
            children.iter()
                .filter(|child| child["type"] == "function")
                .count()
        } else {
            0
        }
    }

    /// Run the MCP server
    pub async fn run(&self) -> Result<()> {
        info!("🚀 Live Function Tree MCP Server starting...");
        
        let stdin = std::io::stdin();
        let mut stdout = std::io::stdout();
        
        for line in stdin.lock().lines() {
            let line = line?;
            
            match serde_json::from_str::<McpRequest>(&line) {
                Ok(request) => {
                    match self.handle_request(request).await {
                        Ok(response) => {
                            let response_json = serde_json::to_string(&response)?;
                            writeln!(stdout, "{}", response_json)?;
                            stdout.flush()?;
                        }
                        Err(e) => {
                            error!("Error handling request: {}", e);
                            let error_response = McpResponse {
                                jsonrpc: "2.0".to_string(),
                                id: 1,
                                result: None,
                                error: Some(json!({
                                    "code": -32603,
                                    "message": format!("Internal error: {}", e)
                                })),
                            };
                            let response_json = serde_json::to_string(&error_response)?;
                            writeln!(stdout, "{}", response_json)?;
                            stdout.flush()?;
                        }
                    }
                }
                Err(e) => {
                    error!("Failed to parse request: {}", e);
                }
            }
        }
        
        Ok(())
    }
}