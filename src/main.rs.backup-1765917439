//! 🚀 Live Function Tree MCP - Ultra-fast PSI/CFG function indexing
//! 
//! Extracted core functions from Ultra-Brain for lightning-fast function tree operations:
//! - lft_index_project: Build PSI graph (milisekundy!)
//! - lft_query_functions: Fast function queries
//! - lft_get_function_tree: Hierarchical clean tree
//! - lft_get_stats: Real-time statistics
//! 
//! Performance: 100x faster than Node.js, instant reindex on file changes

use serde::{Deserialize, Serialize};
use serde_json::{json, Value};
use std::collections::HashMap;
use std::io::{BufRead, BufReader, Write};
use std::sync::Arc;
use tokio::sync::Mutex;
use anyhow::{Result, Context};
use log::{info, error, debug};

mod psi_graph;
mod function_extractor;
mod file_watcher;
mod junk_filter;
mod mcp_protocol;

use psi_graph::{PsiGraphManager, IndexResult, FunctionInfo};
use file_watcher::FileWatcher;
use junk_filter::JunkFilter;
use mcp_protocol::{McpRequest, McpResponse, Tool};

/// Main Live Function Tree MCP Server
pub struct LiveFunctionTreeMcp {
    psi_manager: Arc<PsiGraphManager>,
    file_watcher: Arc<Mutex<Option<FileWatcher>>>,
    junk_filter: JunkFilter,
}

impl LiveFunctionTreeMcp {
    /// Create new Live Function Tree MCP server
    pub async fn new() -> Result<Self> {
        let psi_manager = Arc::new(PsiGraphManager::new().await?);
        let file_watcher = Arc::new(Mutex::new(None));
        let junk_filter = JunkFilter::new();

        Ok(Self {
            psi_manager,
            file_watcher,
            junk_filter,
        })
    }

    /// Handle MCP request
    pub async fn handle_request(&self, request: McpRequest) -> Result<McpResponse> {
        match request.method.as_str() {
            "tools/list" => self.list_tools().await,
            "tools/call" => self.call_tool(request.params).await,
            _ => Err(anyhow::anyhow!("Unknown method: {}", request.method)),
        }
    }

