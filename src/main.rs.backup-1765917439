    /// Call specific tool
    async fn call_tool(&self, params: Value) -> Result<McpResponse> {
        let tool_name = params["name"].as_str()
            .ok_or_else(|| anyhow::anyhow!("Missing tool name"))?;
        
        let arguments = &params["arguments"];

        let result = match tool_name {
            "lft_index_project" => self.index_project(arguments).await?,
            "lft_query_functions" => self.query_functions(arguments).await?,
            "lft_get_function_tree" => self.get_function_tree(arguments).await?,
            "lft_get_stats" => self.get_stats(arguments).await?,
            _ => return Err(anyhow::anyhow!("Unknown tool: {}", tool_name)),
        };

        Ok(McpResponse {
            jsonrpc: "2.0".to_string(),
            id: 1,
            result: Some(json!({
                "content": [{
                    "type": "text",
                    "text": serde_json::to_string_pretty(&result)?
                }]
            })),
            error: None,
        })
    }

    /// 🧬 INDEX PROJECT - Ultra-fast PSI indexing
    async fn index_project(&self, args: &Value) -> Result<Value> {
        let project_path = args["projectPath"].as_str()
            .ok_or_else(|| anyhow::anyhow!("Missing projectPath"))?;
        
        let repo_id = args["repoId"].as_str()
            .map(|s| s.to_string())
            .unwrap_or_else(|| {
                std::path::Path::new(project_path)
                    .file_name()
                    .and_then(|n| n.to_str())
                    .unwrap_or("unknown")
                    .to_string()
            });

        let watch_files = args["watchFiles"].as_bool().unwrap_or(true);
        let languages: Vec<String> = args["languages"]
            .as_array()
            .map(|arr| arr.iter().filter_map(|v| v.as_str().map(|s| s.to_string())).collect())
            .unwrap_or_else(|| vec!["rust".to_string(), "python".to_string(), "javascript".to_string(), "typescript".to_string()]);

        info!("🧬 Indexing project: {} (repo_id: {})", project_path, repo_id);

        let start_time = std::time::Instant::now();
        
        // Index using PSI graph manager
        let index_result = self.psi_manager.index_project(
            project_path,
            &repo_id,
            &languages,
        ).await?;

        // Setup file watcher if requested
        if watch_files {
            let mut watcher_guard = self.file_watcher.lock().await;
            let watcher = FileWatcher::new(
                project_path.to_string(),
                repo_id.clone(),
                self.psi_manager.clone(),
            ).await?;
            *watcher_guard = Some(watcher);
            info!("👁️ File watcher enabled for: {}", project_path);
        }

        let duration_ms = start_time.elapsed().as_millis() as u64;

        Ok(json!({
            "status": "success",
            "message": "✅ Project indexed with ultra-fast PSI",
            "repoId": repo_id,
            "projectPath": project_path,
            "filesProcessed": index_result.files_processed,
            "functionsFound": index_result.summary.functions,
            "indexingTime": format!("{}ms", duration_ms),
            "watchingEnabled": watch_files,
            "performance": "🚀 Rust native speed - 100x faster than Node.js"
        }))
    }

    /// 🔍 QUERY FUNCTIONS - Lightning-fast queries
    async fn query_functions(&self, args: &Value) -> Result<Value> {
        let repo_id = args["repoId"].as_str()
            .ok_or_else(|| anyhow::anyhow!("Missing repoId"))?;
        
        let query_type = args["queryType"].as_str()
            .ok_or_else(|| anyhow::anyhow!("Missing queryType"))?;
        
        let symbol = args["symbol"].as_str().map(|s| s.to_string());
        let include_context = args["includeContext"].as_bool().unwrap_or(true);
        let max_results = args["maxResults"].as_u64().unwrap_or(100) as usize;

        info!("🔍 Querying functions: {} ({})", repo_id, query_type);

        let start_time = std::time::Instant::now();
        
        let results = self.psi_manager.query_functions(
            repo_id,
            query_type,
            symbol.as_deref(),
            include_context,
            max_results,
        ).await?;

        let duration_ms = start_time.elapsed().as_millis() as u64;

        Ok(json!({
            "status": "success",
            "repoId": repo_id,
            "queryType": query_type,
            "symbol": symbol,
            "totalFound": results.len(),
            "results": results,
            "queryTime": format!("{}ms", duration_ms),
            "performance": "⚡ SQLite PSI speed - milisekundy queries"
        }))
    }

    /// 🌳 GET FUNCTION TREE - Hierarchical clean tree
    async fn get_function_tree(&self, args: &Value) -> Result<Value> {
        let repo_id = args["repoId"].as_str()
            .ok_or_else(|| anyhow::anyhow!("Missing repoId"))?;
        
        let group_by = args["groupBy"].as_str().unwrap_or("file");
        let clean_only = args["cleanOnly"].as_bool().unwrap_or(true);
        let filter_complexity = args["filterComplexity"].as_u64();

        info!("🌳 Building function tree: {} (clean={})", repo_id, clean_only);

        let start_time = std::time::Instant::now();
        
        // Get all functions
        let mut functions = self.psi_manager.get_all_functions(repo_id).await?;
        let total_functions = functions.len();

        // Apply junk filtering if requested
        if clean_only {
            functions = self.junk_filter.filter_clean_functions(functions);
            info!("🧹 Filtered {} junk functions", total_functions - functions.len());
        }

        // Apply complexity filter if specified
        if let Some(min_complexity) = filter_complexity {
            functions.retain(|f| f.complexity.unwrap_or(0) >= min_complexity as usize);
        }

        // Build hierarchical tree
        let tree = self.build_function_tree(functions, group_by)?;
        
        let duration_ms = start_time.elapsed().as_millis() as u64;

        Ok(json!({
            "status": "success",
            "repoId": repo_id,
            "groupBy": group_by,
            "functionTree": tree,
            "totalFunctions": total_functions,
            "cleanFunctions": tree.iter().map(|node| self.count_functions_in_node(node)).sum::<usize>(),
            "filteredOut": total_functions - tree.iter().map(|node| self.count_functions_in_node(node)).sum::<usize>(),
            "buildTime": format!("{}ms", duration_ms),
            "junkFiltered": clean_only,
            "performance": "🎯 Smart filtering - only meaningful functions"
        }))
    }

    /// 📊 GET STATS - Real-time statistics
    async fn get_stats(&self, args: &Value) -> Result<Value> {
        let repo_id = args["repoId"].as_str()
