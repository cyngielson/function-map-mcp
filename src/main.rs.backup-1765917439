        info!("📊 Getting stats for: {}", repo_id);

        let stats = self.psi_manager.get_project_stats(repo_id).await?;

        Ok(json!({
            "status": "success",
            "repoId": repo_id,
            "stats": {
                "totalNodes": stats.total_nodes,
                "totalEdges": stats.total_edges,
