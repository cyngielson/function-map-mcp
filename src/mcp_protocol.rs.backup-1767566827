    /// Handle get hierarchical tree
    async fn handle_get_hierarchical_tree(&self, args: &Value) -> Result<String> {
        // Tree is READ-ONLY: it should never implicitly index or create repo entries.
        // Preferred input is repo_id. We still accept project_path, but ONLY as a lookup.
        let repo_id: String = if let Some(repo_id) = args.get("repo_id").and_then(|r| r.as_str()) {
            repo_id.to_string()
        } else if let Some(project_path) = args.get("project_path").and_then(|p| p.as_str()) {
            self.psi_manager.find_repo_id_by_project_path(project_path).await?
                .ok_or_else(|| anyhow!(
                    "Project '{}' is not indexed yet. Run lft_index_project first.",
                    project_path
                ))?
        } else {
            return Err(anyhow!("Missing repo_id (preferred) or project_path parameter"));
        };

        let apply_filtering = args.get("apply_filtering")
            .and_then(|f| f.as_bool())
            .unwrap_or(true);

        let min_complexity = args.get("min_complexity")
            .and_then(|c| c.as_u64())
            .unwrap_or(1) as usize;

        let include_private = args.get("include_private")
            .and_then(|p| p.as_bool())
            .unwrap_or(false);

        let group_by_file = args.get("group_by_file")
            .and_then(|g| g.as_bool())
            .unwrap_or(true);

        let include_context = args.get("include_context")
            .and_then(|c| c.as_bool())
            .unwrap_or(true);

        let context_lines = args.get("context_lines")
            .and_then(|l| l.as_u64())
            .unwrap_or(5) as usize;

        let output_format = args.get("output_format")
            .and_then(|f| f.as_str())
            .unwrap_or("json");

        let include_cross_refs = args.get("include_cross_refs")
            .and_then(|c| c.as_bool())
            .unwrap_or(true);

        // Build hierarchical tree (read-only) from already indexed repository
        let tree = self.hierarchical_builder
            .build_tree_by_repo_id(&repo_id, include_context, context_lines)
            .await?;

        // Create enhanced display
        let display = self.hierarchical_builder.create_display(tree);

        // Format output based on requested format
        match output_format {
            "json-compressed" => {
                use std::io::Write;
                use flate2::{write::GzEncoder, Compression};
                use base64::Engine;

                let json_str = serde_json::to_string(&display)?;
                let mut encoder = GzEncoder::new(Vec::new(), Compression::default());
                encoder.write_all(json_str.as_bytes())?;
                let compressed = encoder.finish()?;
                let encoded = base64::engine::general_purpose::STANDARD.encode(&compressed);

                Ok(serde_json::to_string(&serde_json::json!({
                    "format": "json-compressed",
                    "data": encoded,
                    "original_size": json_str.len(),
                    "compressed_size": compressed.len()
                }))?)
            },
            "bincode" => {
                use base64::Engine;
                let binary = bincode::serialize(&display)?;
                let encoded = base64::engine::general_purpose::STANDARD.encode(&binary);

                Ok(serde_json::to_string(&serde_json::json!({
                    "format": "bincode",
                    "data": encoded,
                    "size": binary.len()
                }))?)
            },
            _ => {
                // Default JSON format with enhanced display
                Ok(serde_json::to_string_pretty(&display)?)
            }
        }
    }

