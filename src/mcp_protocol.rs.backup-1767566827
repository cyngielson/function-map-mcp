impl McpProtocolHandler {
    /// Create new protocol handler
    pub async fn new() -> Result<Self> {
        let psi_manager = PsiGraphManager::new().await?;

        // Pre-load ALL functions into memory cache for instant queries
        info!("🚀 Pre-loading function cache into RAM...");
        match psi_manager.load_into_memory_cache().await {
            Ok(count) => info!("✅ Loaded {} functions into memory cache", count),
            Err(e) => info!("⚠️ Cache pre-load skipped: {}", e),
        }

        Ok(Self {
            psi_manager,
            extractor: FunctionExtractor::new(),
            file_watcher: None,
            hierarchical_builder: HierarchicalTreeBuilder::new().await?,
        })
    }

