    pub fn get_server_info(&self) -> Value {
        json!({
            "name": "live-function-tree-mcp",
            "version": "0.1.0",
            "protocolVersion": MCP_VERSION,
            "protocol_version": MCP_VERSION  // Keep both for compatibility
        })
    }

    /// Process MCP request
    pub async fn process_request(&mut self, method: &str, request: &JsonRpcRequest) -> Result<Value> {
        debug!("🔄 Processing request: {}", method);

        match method {
            "tools/list" => self.handle_list_tools().await,
            "tools/call" => self.handle_tool_call(&request).await,
            "notifications/initialized" => self.handle_initialized().await,
            _ => Err(anyhow!("Unsupported method: {}", method))
        }
    }

    /// Initialize protocol
    pub async fn initialize(&mut self, _params: Option<Value>) -> Result<Value> {
        info!("🚀 Initializing Live Function Tree MCP Server");

        Ok(json!({
            "protocolVersion": MCP_VERSION,
            "protocol_version": MCP_VERSION,  // Keep both for compatibility
            "capabilities": {
                "tools": {
                    "listChanged": false,
                    "list_changed": false  // Keep both for compatibility
                }
            },
            "serverInfo": self.get_server_info(),
            "server_info": self.get_server_info()  // Keep both for compatibility
        }))
    }

    /// Handle notifications/initialized
    async fn handle_initialized(&self) -> Result<Value> {
        debug!("✅ Client initialization completed");
        // This is a notification, so we don't need to return anything meaningful
        // Just acknowledge that we received the initialized notification
        Ok(json!(null))
    }

    /// Handle list tools request
    async fn handle_list_tools(&self) -> Result<Value> {
        let tools = self.register_tools();
        info!(
            "🔧 RooCode requested tools/list - returning {} tools",
            tools.len()
        );
        let tools_array: Vec<Value> = tools.into_values()
            .map(|tool| json!(tool))
            .collect();

        info!("📦 Tools being sent to RooCode: {:?}", tools_array.iter().map(|t| t.get("name")).collect::<Vec<_>>());

        Ok(json!({ "tools": tools_array }))
    }

    /// Handle tool call
    async fn handle_tool_call(&mut self, request: &JsonRpcRequest) -> Result<Value> {
        let params = request.params.as_ref()
            .ok_or_else(|| anyhow!("Missing parameters for tool call"))?;

        let arguments = params.get("arguments")
            .ok_or_else(|| anyhow!("Missing arguments"));
        let name = params.get("name")
            .and_then(|n| n.as_str())
            .ok_or_else(|| anyhow!("Missing tool name"))?;

        debug!("🛠️ Executing tool: {}", name);

        let result = match name {
            "lft_snapshot_project" => self.handle_snapshot_project(arguments?).await,
            "lft_index_project" => self.handle_index_project(arguments?).await,
            "lft_index_incremental" => self.handle_index_incremental(arguments?).await,
            "lft_query_functions" => self.handle_query_functions(arguments?).await,
            "lft_get_hierarchical_tree" => self.handle_get_hierarchical_tree(arguments?).await,
            "lft_llm_pack_project" => self.handle_llm_pack_project(arguments?).await,
            "lft_get_stats" => self.handle_get_stats(arguments?).await,
            "lft_start_watch" => self.handle_start_watch(arguments?).await,
            "lft_clear_repository" => self.handle_clear_repository(arguments?).await,
            "lft_list_repositories" => self.handle_list_repositories(arguments?).await,
            "lft_cleanup_old" => self.handle_cleanup_old(arguments?).await,
            "lft_database_stats" => self.handle_database_stats(arguments?).await,
            "lft_optimize_database" => self.handle_optimize_database(arguments?).await,
            "lft_clear_db" => self.handle_clear_db(arguments?).await,
            "lft_search_functions" => self.handle_search_functions(arguments?).await,
            "lft_get_file_functions" => self.handle_get_file_functions(arguments?).await,
            "lft_get_function_details" => self.handle_get_function_details(arguments?).await,
            "lft_get_imports" => self.handle_get_imports(arguments?).await,
            "lft_get_call_graph" => self.handle_get_call_graph(arguments?).await,
            "lft_analyze_cfg" => self.handle_analyze_cfg(arguments?).await,
            "lft_detect_unreachable" => self.handle_detect_unreachable(arguments?).await,
            _ => return Err(anyhow!("Unknown tool: {}", name))
        };

        match result {
            Ok(content) => Ok(json!({
                "content": [{"type": "text", "text": content}],
                "is_error": false
            })),
            Err(e) => Ok(json!({
                "content": [{"type": "text", "text": format!("Error: {}", e)}],
                "is_error": true
            }))
        }
    }

    /// One-shot snapshot: index/ensure indexed then return manifest JSON.
    ///
    /// NOTE:
    /// - We return a JSON string (ToolContent::text) because the current MCP wrapper expects text.
    /// - Clients should parse the returned JSON string.
    async fn handle_snapshot_project(&mut self, args: &Value) -> Result<String> {
        // Opcja dla klienta/LLM: całe wyjście tego toola może być skompresowane.
        // Domyślnie zachowujemy "json" (wsteczna kompatybilność), ale można wymusić:
        // - json-compressed: gzip(JSON) + base64
        // - bincode: bincode(manifest) + base64
        let manifest_output_format = args
            .get("output_format")
            .and_then(|v| v.as_str())
            .unwrap_or("json");

        let ensure_indexed = args
            .get("ensure_indexed")
            .and_then(|v| v.as_bool())
            .unwrap_or(true);

        let reindex_mode = args
            .get("reindex")
            .and_then(|v| v.as_str())
            .unwrap_or("incremental");

        let project_path_opt = args.get("project_path").and_then(|p| p.as_str()).map(|s| s.to_string());

        // repo_id selection priority:
        // 1) explicit repo_id
        // 2) derived from project_path
        // 3) error
        let repo_id = if let Some(id) = args.get("repo_id").and_then(|r| r.as_str()) {
            id.to_string()
        } else if let Some(ref project_path) = project_path_opt {
            self.psi_manager.get_or_create_repo_id(project_path).await?
        } else {
            return Err(anyhow!("Missing repo_id or project_path"));
        };

        // Optional languages: FULL SCAN when omitted.
        let languages: Option<Vec<String>> = args
            .get("languages")
            .and_then(|l| l.as_array())
            .map(|arr| {
                arr.iter()
                    .filter_map(|v| v.as_str())
                    .map(|s| s.to_string())
                    .collect::<Vec<String>>()
            });

        let include_tests = args.get("include_tests").and_then(|t| t.as_bool()).unwrap_or(true);
        let max_files = args.get("max_files").and_then(|m| m.as_u64()).unwrap_or(1000) as usize;

        // Ensure indexed if requested.
        let mut indexing_result: Option<Value> = None;
        if ensure_indexed {
            let project_path = project_path_opt.clone().ok_or_else(|| anyhow!(
                "ensure_indexed=true requires project_path (repo_id alone has no file roots)"
            ))?;

            // If repo exists already and reindex_mode is "none", skip.
            // Otherwise, run incremental/full.
            let should_index = match reindex_mode {
                "none" => {
                    // Validate it exists, otherwise fail with guidance.
                    let exists = self.psi_manager.get_repository_stats(&repo_id).await.is_ok();
                    if !exists {
                        return Err(anyhow!(
                            "Repo '{}' not indexed yet. Either set reindex=incremental/full or run lft_index_project first.",
                            repo_id
                        ));
                    }
                    false
                }
                _ => true,
            };

            if should_index {
                let lang_refs: Option<Vec<&str>> = languages
                    .as_ref()
                    .filter(|v| !v.is_empty())
                    .map(|v| v.iter().map(|s| s.as_str()).collect());

                // We intentionally do NOT change the global behavior of lft_index_project here.
                // Snapshot tool decides whether to run incremental or full.
                let force_full_reindex = matches!(reindex_mode, "full");

                // NOTE: include_tests/max_files are currently not wired into the incremental indexer
                // signature; they are kept for forward compatibility and future enforcement.
                let _ = (include_tests, max_files);

                let idx = self
                    .psi_manager
                    .index_project_incremental(
                        &project_path,
                        &repo_id,
                        lang_refs.as_ref().map(|v| v.as_slice()),
                        force_full_reindex,
                    )
                    .await?;

                self.psi_manager.warm_cache_if_enabled().await?;

                indexing_result = Some(serde_json::to_value(idx)?);
            }
        }

        // Collect snapshot pieces.
        let stats = self.psi_manager.get_repository_stats(&repo_id).await?;

        let tree_opts = args.get("tree");
        let tree_include_context = tree_opts
            .and_then(|t| t.get("include_context"))
            .and_then(|v| v.as_bool())
            .unwrap_or(true);
        let tree_context_lines = tree_opts
            .and_then(|t| t.get("context_lines"))
            .and_then(|v| v.as_u64())
            .unwrap_or(2) as usize;
        let tree_output_format = tree_opts
            .and_then(|t| t.get("output_format"))
            .and_then(|v| v.as_str())
            .unwrap_or("json");
        let tree_include_cross_refs = tree_opts
            .and_then(|t| t.get("include_cross_refs"))
            .and_then(|v| v.as_bool())
            .unwrap_or(true);

        let tree = self
            .hierarchical_builder
            .build_tree_by_repo_id(&repo_id, tree_include_context, tree_context_lines)
            .await?;
        let tree_display = self.hierarchical_builder.create_display(tree);

        // Imports (project-wide)
        let imports = self.psi_manager.get_imports(&repo_id, None, true, true).await?;

        // Call graph
        let cg_opts = args.get("call_graph");
        let cg_depth = cg_opts
            .and_then(|c| c.get("depth"))
            .and_then(|v| v.as_u64())
            .unwrap_or(2) as usize;
        let cg_direction = cg_opts
            .and_then(|c| c.get("direction"))
            .and_then(|v| v.as_str())
            .unwrap_or("both")
            .to_string();
        let cg_include_external = cg_opts
            .and_then(|c| c.get("include_external"))
            .and_then(|v| v.as_bool())
            .unwrap_or(false);

        let call_graph = self
            .psi_manager
            .get_call_graph(&repo_id, None, cg_depth, &cg_direction, cg_include_external)
            .await?;

        // Format tree according to output_format.
        let tree_payload: Value = match tree_output_format {
            "json-compressed" => {
                use std::io::Write;
                use flate2::{write::GzEncoder, Compression};
                use base64::Engine;
                let json_str = serde_json::to_string(&tree_display)?;
                let mut encoder = GzEncoder::new(Vec::new(), Compression::default());
                encoder.write_all(json_str.as_bytes())?;
                let compressed = encoder.finish()?;
                let encoded = base64::engine::general_purpose::STANDARD.encode(&compressed);
                json!({
                    "format": "json-compressed",
                    "data": encoded,
                    "original_size": json_str.len(),
                    "compressed_size": compressed.len()
                })
            }
            "bincode" => {
                use base64::Engine;
                let binary = bincode::serialize(&tree_display)?;
                let encoded = base64::engine::general_purpose::STANDARD.encode(&binary);
                json!({
                    "format": "bincode",
                    "data": encoded,
                    "binary_size": binary.len()
                })
            }
            _ => serde_json::to_value(&tree_display)?,
        };

        let manifest = json!({
            "tool": "lft_snapshot_project",
            "repo_id": repo_id,
            "project_path": project_path_opt,
            "output_format": manifest_output_format,
            "indexing": {
                "ensure_indexed": ensure_indexed,
                "reindex": reindex_mode,
                "languages": languages,
                "include_tests": include_tests,
                "max_files": max_files,
                "result": indexing_result
            },
            "snapshot": {
                "stats": stats,
                "tree": {
                    "options": {
                        "include_context": tree_include_context,
                        "context_lines": tree_context_lines,
                        "include_cross_refs": tree_include_cross_refs,
                        "output_format": tree_output_format
                    },
                    "data": tree_payload
                },
                "imports": imports,
                "call_graph": call_graph
            }
        });

        // Format całego manifestu zgodnie z output_format.
        let out = match manifest_output_format {
            "json-compressed" => {
                use std::io::Write;
                use base64::Engine;
                use flate2::{write::GzEncoder, Compression};

                let json_str = serde_json::to_string(&manifest)?;
                let mut encoder = GzEncoder::new(Vec::new(), Compression::default());
                encoder.write_all(json_str.as_bytes())?;
                let compressed = encoder.finish()?;
                let encoded = base64::engine::general_purpose::STANDARD.encode(&compressed);

                // Zwracamy mały wrapper JSON, żeby klient wiedział co dostał bez zgadywania.
                json!({
                    "format": "json-compressed",
                    "data": encoded,
                    "original_size": json_str.len(),
                    "compressed_size": compressed.len()
                })
                .to_string()
            }
            "bincode" => {
                use base64::Engine;
                let binary = bincode::serialize(&manifest)?;
                let encoded = base64::engine::general_purpose::STANDARD.encode(&binary);
                json!({
                    "format": "bincode",
                    "data": encoded,
                    "binary_size": binary.len()
                })
                .to_string()
            }
            _ => serde_json::to_string(&manifest)?,
        };

        Ok(out)
    }

    // LLM pack: uruchamia snapshot wewnetrznie i zwraca ZWIEZLY raport tekstowy (bez dumpowania drzewa/callgraph).
    // To jest kluczowe na Windows i w czatach LLM: zamiast 300k linii dostajesz "mape" + metryki + instrukcje.
    async fn handle_llm_pack_project(&mut self, args: &Value) -> Result<String> {
        let include_snapshot_payload = args
            .get("include_snapshot_payload")
            .and_then(|v| v.as_bool())
            .unwrap_or(false);
        let snapshot_payload_format = args
            .get("snapshot_payload_format")
            .and_then(|v| v.as_str())
            .unwrap_or("json-compressed");

        // 1) Zawsze robimy snapshot w JSON do analizy (lokalnie, w pamieci), bo musimy wyciagnac metryki.
        let mut snap_args_json = args.clone();
        if let Some(obj) = snap_args_json.as_object_mut() {
            obj.insert("output_format".to_string(), Value::String("json".to_string()));
        }
        let snapshot_text_json = self.handle_snapshot_project(&snap_args_json).await?;
        let snapshot_json: Value = serde_json::from_str(&snapshot_text_json)?;

        // 2) Opcjonalnie: drugi snapshot jako payload (skompresowany wrapper), do przeniesienia offline.
        let snapshot_payload_wrapper: Option<String> = if include_snapshot_payload {
            let mut snap_args_payload = args.clone();
            if let Some(obj) = snap_args_payload.as_object_mut() {
                obj.insert(
                    "output_format".to_string(),
                    Value::String(snapshot_payload_format.to_string()),
                );
            }
            Some(self.handle_snapshot_project(&snap_args_payload).await?)
        } else {
            None
        };

        let repo_id = snapshot_json
            .get("repo_id")
            .and_then(|v| v.as_str())
            .unwrap_or("(unknown)");
        let project_path = snapshot_json
            .get("project_path")
            .and_then(|v| v.as_str())
            .unwrap_or("(unknown)");

        let stats = snapshot_json
            .pointer("/snapshot/stats")
            .cloned()
            .unwrap_or(Value::Null);

        let nodes_total = stats.get("total_nodes").and_then(|v| v.as_u64()).unwrap_or(0);
        let edges_total = stats.get("total_edges").and_then(|v| v.as_u64()).unwrap_or(0);
        let files_tracked = stats.get("files_tracked").and_then(|v| v.as_u64()).unwrap_or(0);
        let node_types = stats
            .get("node_types")
            .and_then(|v| v.as_object())
            .cloned()
            .unwrap_or_default();

        let functions_count = node_types.get("function").and_then(|v| v.as_u64()).unwrap_or(0);
        let classes_count = node_types.get("class").and_then(|v| v.as_u64()).unwrap_or(0);

        let cg = snapshot_json
            .pointer("/snapshot/call_graph")
            .cloned()
            .unwrap_or(Value::Null);
        let cg_nodes = cg.get("nodes").and_then(|v| v.as_array()).map(|a| a.len()).unwrap_or(0);
        let cg_edges = cg.get("edges").and_then(|v| v.as_array()).map(|a| a.len()).unwrap_or(0);

        let imports = snapshot_json
            .pointer("/snapshot/imports")
            .cloned()
            .unwrap_or(Value::Null);
        let imports_total = imports.get("total_imports").and_then(|v| v.as_u64()).unwrap_or(0);
        // `get_imports(..., group_by_file=true)` returns:
        // - files_analyzed: number of files that had at least 1 import (because we only insert non-empty)
        // - imports_by_file: object mapping file_path -> [imports]
        // For group_by_file=false it returns: { total_imports, imports: [...] }
        let files_with_imports = imports
            .get("files_analyzed")
            .and_then(|v| v.as_u64())
            .or_else(|| {
                imports
                    .get("imports_by_file")
                    .and_then(|v| v.as_object())
                    .map(|o| o.len() as u64)
            })
            .or_else(|| imports.get("imports").and_then(|v| v.as_array()).map(|_| 0u64))
            .unwrap_or(0);

        let tree_opts = snapshot_json
            .pointer("/snapshot/tree/options")
            .cloned()
            .unwrap_or(Value::Null);

        // --- Tree-derived summaries (no full dump) ---
        // The snapshot tree can be:
        // - full JSON (HierarchicalTreeDisplay)
        // - or compressed wrapper (tree.output_format != json)
        // We only compute top-lists when the tree is available as JSON.
        // NOTE: `lft_snapshot_project` stores tree payload under `snapshot.tree.data`.
        // `snapshot.tree.options` keeps the options.
        let tree_value = snapshot_json
            .pointer("/snapshot/tree/data")
            .cloned()
            .unwrap_or(Value::Null);
        let tree_display = if tree_value.is_object() {
            tree_value.as_object().cloned()
        } else {
            None
        };

        let mut top_files_by_functions: Vec<(String, u64)> = Vec::new();
        let mut top_complexity_functions: Vec<(String, String, Option<u64>, String)> = Vec::new();
        if let Some(tree_obj) = tree_display {
            if let Some(file_summary) = tree_obj.get("file_summary").and_then(|v| v.as_array()) {
                for item in file_summary {
                    let rel = item
                        .get("relative_path")
                        .and_then(|v| v.as_str())
                        .unwrap_or("(unknown)")
                        .to_string();
                    let cnt = item.get("function_count").and_then(|v| v.as_u64()).unwrap_or(0);
                    top_files_by_functions.push((rel, cnt));
                }
            }

            if let Some(top_functions) = tree_obj.get("top_functions").and_then(|v| v.as_array()) {
                for tf in top_functions {
                    let name = tf.get("name").and_then(|v| v.as_str()).unwrap_or("(unknown)").to_string();
                    let file_path = tf
                        .get("file_path")
                        .and_then(|v| v.as_str())
                        .unwrap_or("(unknown)")
                        .to_string();
                    let rel_path = if project_path != "(unknown)" && file_path.to_lowercase().starts_with(&project_path.to_lowercase()) {
                        file_path[project_path.len()..].trim_start_matches(['\\', '/']).to_string()
                    } else {
                        file_path.clone()
                    };
                    let complexity = tf.get("complexity").and_then(|v| v.as_u64());
                    let line_range = tf.get("line_range").and_then(|v| v.as_str()).unwrap_or("?").to_string();
                    top_complexity_functions.push((name, rel_path, complexity, line_range));
                }
            }
        }

        // --- Call-graph hubs (degree) ---
        // We compute degree for nodes based on edges; this stays compact even if edges are large-ish.
        let mut hub_degree: HashMap<String, u64> = HashMap::new();
        if let Some(edges) = cg.get("edges").and_then(|v| v.as_array()) {
            for e in edges {
                // Expected shape: {from,to,...} (robust fallback for alternative keys)
                let from = e.get("from")
                    .or_else(|| e.get("source"))
                    .and_then(|v| v.as_str());
                let to = e.get("to")
                    .or_else(|| e.get("target"))
                    .and_then(|v| v.as_str());

                if let Some(f) = from {
                    *hub_degree.entry(f.to_string()).or_insert(0) += 1;
                }
                if let Some(t) = to {
                    *hub_degree.entry(t.to_string()).or_insert(0) += 1;
                }
            }
        }

        let mut top_hubs: Vec<(String, u64)> = hub_degree.into_iter().collect();
        top_hubs.sort_by(|a, b| b.1.cmp(&a.1));
        top_hubs.truncate(20);

        // --- Entrypoint hints (pure heuristic on filenames, still truth-from-files) ---
        let mut entrypoint_candidates: Vec<(String, u64)> = top_files_by_functions
            .iter()
            .filter(|(p, _)| {
                let s = p.to_lowercase();
                s.contains("main")
                    || s.contains("app")
                    || s.contains("api")
                    || s.contains("server")
                    || s.contains("router")
                    || s.contains("dispatch")
                    || s.contains("wsgi")
                    || s.contains("asgi")
            })
            .cloned()
            .collect();
        entrypoint_candidates.truncate(10);

        let mut report = String::new();
        report.push_str("RAPORT (prawda z kodu) - LFT LLM PACK\n");
        report.push_str("================================\n\n");
        report.push_str(&format!("Repo: {}\n", repo_id));
        report.push_str(&format!("Project path: {}\n\n", project_path));

        report.push_str("1) Skala i metryki\n");
        report.push_str(&format!("- files_tracked: {}\n", files_tracked));
        report.push_str(&format!("- functions: {}\n", functions_count));
        report.push_str(&format!("- classes: {}\n", classes_count));
        report.push_str(&format!("- psi_graph nodes/edges: {}/{}\n", nodes_total, edges_total));
        report.push_str(&format!("- call_graph nodes/edges: {}/{}\n", cg_nodes, cg_edges));
        report.push_str(&format!("- imports: total_imports={}, files_with_imports={}\n\n", imports_total, files_with_imports));

        report.push_str("2) Najbardziej wartosciowe do zrozumienia (kolejnosc)\n");
        report.push_str("- Hierarchical tree + kontekst: mapa modulow i funkcji (glowny punkt startowy).\n");
        report.push_str("- Imports: spina architekture (warstwy, huby, cykle).\n");
        report.push_str("- Call graph: weryfikuje przeplyw sterowania (impact, who-calls-who).\n\n");

        report.push_str("3) Parametry tree w tym runie\n");
        report.push_str(&format!("- tree.options: {}\n\n", serde_json::to_string(&tree_opts)?));

        report.push_str("4) Top pliki i funkcje (z tree, bez dumpowania drzewa)\n");
        if top_files_by_functions.is_empty() {
            report.push_str("- top files: (brak - tree jest skompresowane lub puste; ustaw tree.output_format=json jesli chcesz te sekcje)\n");
        } else {
            report.push_str("- Top 10 plikow wg liczby funkcji:\n");
            for (i, (p, c)) in top_files_by_functions.iter().take(10).enumerate() {
                report.push_str(&format!("  {}. {} ({} funkcji)\n", i + 1, p, c));
            }
        }

        if !top_complexity_functions.is_empty() {
            report.push_str("- Top funkcje wg complexity (proxy na 'hotspoty'):\n");
            for (i, (name, rel_path, cx, line_range)) in top_complexity_functions.iter().take(10).enumerate() {
                let cx_s = cx.map(|v| v.to_string()).unwrap_or_else(|| "?".to_string());
                report.push_str(&format!("  {}. {} (cx={}, {}:{})\n", i + 1, name, cx_s, rel_path, line_range));
            }
        }

        if !entrypoint_candidates.is_empty() {
            report.push_str("- Kandidaci na entrypointy (heurystyka po nazwie pliku):\n");
            for (i, (p, c)) in entrypoint_candidates.iter().enumerate() {
                report.push_str(&format!("  {}. {} ({} funkcji)\n", i + 1, p, c));
            }
        }

        report.push_str("\n5) Huby z call-graph (degree)\n");
        if top_hubs.is_empty() {
            report.push_str("- (brak danych call graph)\n");
        } else {
            report.push_str("- Top 20 nazw funkcji (najczesciej polaczone w grafie wywolan):\n");
            for (i, (name, deg)) in top_hubs.iter().enumerate() {
                report.push_str(&format!("  {}. {} (degree={})\n", i + 1, name, deg));
            }
            report.push_str("- Jak wyciagnac kontekst hubow: uzyj lft_get_function_details {repo_id, function_name, context_lines}.\n");
        }

    report.push_str("\n6) Co teraz zrobic, zeby 'zrozumiec system' (konkret)\n");
    report.push_str("- Wez 3 pierwsze pliki z Top 10 i odpal lft_get_file_functions (include_body=true) - to da 'prawde z kodu' w malych porcjach.\n");
    report.push_str("- Wez 5 pierwszych hubow i odpal lft_get_function_details (include_callers/include_callees=true) - zobaczysz faktyczny przeplyw.\n");
    report.push_str("- Dla entrypoint kandidatow: szukaj w nich wywolan do router/dispatcher/pricing/payment.\n\n");

        if let Some(wrapper) = snapshot_payload_wrapper {
            report.push_str("7) Snapshot payload (skompresowany wrapper JSON)\n");
            report.push_str("SNAPSHOT_PAYLOAD_JSON_WRAPPER_BEGIN\n");
            report.push_str(&wrapper);
            report.push_str("\nSNAPSHOT_PAYLOAD_JSON_WRAPPER_END\n");
        }

        Ok(report)
    }

    /// Handle index project
    async fn handle_index_project(&mut self, args: &Value) -> Result<String> {
        let project_path = args.get("project_path")
            .and_then(|p| p.as_str())
            .ok_or_else(|| anyhow!("Missing project_path parameter"))?;

        // 🔥 ZAWSZE generujemy repo_id z project_path żeby uniknąć duplikatów w bazie
        // Ignorujemy user-provided repo_id - project_path jest źródłem prawdy
        let repo_id = self.psi_manager.get_or_create_repo_id(project_path).await?;

        // Log if user provided different repo_id for consistency check
        if let Some(user_repo_id) = args.get("repo_id").and_then(|r| r.as_str()) {
            if user_repo_id != repo_id {
                info!("🔄 User provided repo_id '{}' but using generated '{}' for path: {}",
                      user_repo_id, repo_id, project_path);
            }
        }

        // ZASADA: jak user nie poda `languages`, to robimy FULL SCAN projektu (katalog projektu = zakres).
        // Czyli nie filtrujemy po języku w ogóle, tylko bierzemy wszystkie wspierane rozszerzenia,
        // a śmieci tniemy wyłącznie przez hard skip-listy (node_modules/venv/target/etc.).
        //
        // Filtr językowy włączamy TYLKO gdy `languages` jest jawnie podane.
        let languages: Option<Vec<String>> = args.get("languages")
            .and_then(|l| l.as_array())
            .map(|arr| arr.iter()
                .filter_map(|v| v.as_str())
                .map(|s| s.to_string())
                .collect());

        let include_tests = args.get("include_tests")
            .and_then(|t| t.as_bool())
            .unwrap_or(true);

        let max_files = args.get("max_files")
            .and_then(|m| m.as_u64())
            .unwrap_or(1000) as usize;

        // 🔥 NOWA LOGIKA: mode parametr decyduje o strategii indeksowania
        let mode = args.get("mode")
            .and_then(|m| m.as_str())
            .unwrap_or("incremental");

        match mode {
            "replace" => {
                info!("🔄 Replace mode: clearing existing index for repo_id: {}", repo_id);
                // Usuń stary indeks
                if let Err(e) = self.psi_manager.clear_repository(&repo_id).await {
                    warn!("Failed to clear repository {}: {}", repo_id, e);
                }
            }
            "incremental" => {
                info!("⚡ Incremental mode: indexing only changed files for repo_id: {}", repo_id);
            }
            _ => {
                return Err(anyhow!("Invalid mode: {}. Use 'incremental' or 'replace'", mode));
            }
        }

        info!("🧬 Indexing project: {} (repo_id: {}, mode: {})", project_path, repo_id, mode);

        let lang_refs: Option<Vec<&str>> = languages
            .as_ref()
            .filter(|v| !v.is_empty())
            .map(|v| v.iter().map(|s| s.as_str()).collect());

        let index_result = self.psi_manager.index_project_incremental(
            project_path,
            &repo_id,
            lang_refs.as_ref().map(|v| v.as_slice()),
            false, // force_full_reindex = false, bo w replace mode już wyczyściliśmy bazę
        ).await?;

        // Cache: nie preloadujemy plików do RAM domyślnie (to jest ciężkie na Windows).
        self.psi_manager.warm_cache_if_enabled().await?;

        // NOTE(Windows/encoding): MCP clients commonly spawn the server with default console
        // encoding (often cp1252). Unicode emoji can crash clients when they try to decode
        // stdout/stderr as "text". Keep tool output ASCII by default.
        let ascii_only = std::env::var("LFT_ASCII_ONLY")
            .map(|v| matches!(v.to_lowercase().as_str(), "1" | "true" | "yes"))
            .unwrap_or(true);

        // Tekst identyczny niezależnie od ascii_only, ale zostawiamy bramkę na przyszłość.
        if ascii_only {
            Ok(format!(
                "Successfully indexed {} functions from project '{}' (repo_id: {})",
                index_result.total_nodes,
                project_path,
                repo_id
            ))
        } else {
            Ok(format!(
                "Successfully indexed {} functions from project '{}' (repo_id: {})",
                index_result.total_nodes,
                project_path,
                repo_id
            ))
        }
    }

