    /// Handle CFG analysis for function or file
    async fn handle_analyze_cfg(&self, args: &Value) -> Result<String> {
        let file_path = args.get("file_path")
            .and_then(|f| f.as_str())
            .ok_or_else(|| anyhow!("Missing file_path parameter"))?;

        let function_name = args.get("function_name")
            .and_then(|f| f.as_str());

        let include_context = args.get("include_context")
            .and_then(|i| i.as_bool())
            .unwrap_or(true);

        let context_lines = args.get("context_lines")
            .and_then(|c| c.as_u64())
            .unwrap_or(3) as usize;

        info!("🔍 Analyzing CFG for file: {}", file_path);

        // Read file content
        let content = std::fs::read_to_string(file_path)
            .map_err(|e| anyhow!("Failed to read file {}: {}", file_path, e))?;

        let analyzer = SimpleCfgAnalyzer;
        let mut results = Vec::new();

        if let Some(func_name) = function_name {
            // Analyze specific function - find function bounds
            let lines: Vec<&str> = content.lines().collect();
            let mut start_line = 0;
            let mut end_line = lines.len();

            for (i, line) in lines.iter().enumerate() {
                if line.contains(&format!("fn {}", func_name)) ||
                   line.contains(&format!("def {}", func_name)) ||
                   line.contains(&format!("function {}", func_name)) {
                    start_line = i;
                    let mut brace_count = 0;
                    for (j, l) in lines[i..].iter().enumerate() {
                        brace_count += l.matches('{').count() as i32;
                        brace_count -= l.matches('}').count() as i32;
                        if brace_count == 0 && j > 0 {
                            end_line = i + j + 1;
                            break;
                        }
                    }
                    break;
                }
            }

            let result = analyzer.analyze_function(func_name, file_path, &content, start_line, end_line)?;
            results.push(result);
        } else {
            // Analyze all functions - use tree-sitter
            use crate::tree_sitter_extractor::{TreeSitterExtractor, SupportedLanguage};

            let ext = std::path::Path::new(file_path).extension().and_then(|e| e.to_str()).unwrap_or("");
            if let Some(lang) = SupportedLanguage::from_extension(ext) {
                let mut extractor = TreeSitterExtractor::new()?;
                let functions = extractor.extract_functions(&content, file_path, lang)?;

                for func in functions {
                    let result = analyzer.analyze_function(
                        &func.name, file_path, &content,
                        func.start_line.saturating_sub(1), func.end_line
                    )?;
                    results.push(result);
                }
            } else {
                return Err(anyhow!("Unsupported file extension: {}", ext));
            }
        }

        // Add context if requested
        if include_context {
            let lines: Vec<String> = content.lines().map(|l| l.to_string()).collect();
            for result in &mut results {
                for issue in &mut result.unreachable_issues {
                    let line_num = issue.line_number;
                    let start = line_num.saturating_sub(context_lines).max(1);
                    let end = (line_num + context_lines).min(lines.len());

                    issue.context_before = Some(lines[start.saturating_sub(1)..line_num.saturating_sub(1)]
                        .iter().enumerate().map(|(i, l)| format!("{}: {}", start + i, l)).collect());
                    issue.context_after = Some(lines[line_num..end]
                        .iter().enumerate().map(|(i, l)| format!("{}: {}", line_num + 1 + i, l)).collect());
                }
            }
        }

        let total_issues: usize = results.iter().map(|r| r.unreachable_issues.len()).sum();
        let functions_with_issues = results.iter().filter(|r| r.has_unreachable_code).count();

        let response = json!({
            "file_path": file_path,
            "total_functions_analyzed": results.len(),
            "functions_with_unreachable_code": functions_with_issues,
            "total_unreachable_issues": total_issues,
            "results": results,
            "summary": format!("Analyzed {} function(s): found {} unreachable code block(s) in {} function(s)",
                results.len(), total_issues, functions_with_issues)
        });

        Ok(serde_json::to_string_pretty(&response)?)
    }

    /// Handle project-wide unreachable code detection
    async fn handle_detect_unreachable(&mut self, args: &Value) -> Result<String> {
        let repo_id_opt = args.get("repo_id").and_then(|r| r.as_str());
        let project_path_opt = args.get("project_path").and_then(|p| p.as_str());

        let repo_id = if let Some(rid) = repo_id_opt {
            rid.to_string()
        } else if let Some(path) = project_path_opt {
            self.psi_manager.get_or_create_repo_id(path).await?
        } else {
            return Err(anyhow!("Must provide either repo_id or project_path"));
        };

        let severity_filter = args.get("severity_filter").and_then(|s| s.as_str()).unwrap_or("Medium");
        let max_results = args.get("max_results").and_then(|m| m.as_u64()).unwrap_or(100) as usize;

        info!("🔍 Scanning repo {} for unreachable code", repo_id);

        // Get project path for resolving relative file paths
        let project_path = self.psi_manager.get_project_path(&repo_id).await?
            .ok_or_else(|| anyhow!("Project path not found for repo: {}", repo_id))?;
        info!("📂 Project path: {}", project_path);

        let functions = self.psi_manager.get_all_functions(&repo_id).await?;
        info!("📊 Analyzing {} functions...", functions.len());

        // Filter functions that have unreachable code (from database)
        let functions_with_issues: Vec<_> = functions.iter()
            .filter(|f| f.has_unreachable_code == Some(true))
            .collect();

        info!("🔥 Found {} functions with unreachable code in database", functions_with_issues.len());

        let mut all_issues = Vec::new();
        let mut files_processed = std::collections::HashSet::new();

        // Group functions by file to process all files (not limited by max_results per function)
        let mut file_to_functions = std::collections::HashMap::new();

        for func in functions_with_issues.iter() {
            file_to_functions.entry(func.file_path.clone())
                .or_insert_with(Vec::new)
                .push(func);
        }

        info!("📁 Processing {} unique files with unreachable code", file_to_functions.len());

        // Normalize project path separators for Windows
        let normalized_project_path = project_path.replace("/", "\\");
        info!("🔧 Project path normalized: {} -> {}", project_path, normalized_project_path);

        // Process all files with flagged functions
        for (file_path, file_functions) in file_to_functions.iter() {
            files_processed.insert(file_path.clone());

            // Normalize file path separators for Windows (database may have mixed / and \)
            let normalized_file_path = file_path.replace("/", "\\");

            // Build full file path: normalized_project_path + normalized_file_path
            let full_path = std::path::Path::new(&normalized_project_path).join(&normalized_file_path);

            info!("📄 Reading file: {} + {} = {}",
                  normalized_project_path, normalized_file_path, full_path.display());

            let content = match std::fs::read_to_string(&full_path) {
                Ok(c) => c,
                Err(e) => {
                    warn!("❌ Failed to read file {} (full path: {}): {}",
                          file_path, full_path.display(), e);
                    continue;
                }
            };

            // Process each function in this file
            for func in file_functions.iter() {
                let analyzer = SimpleCfgAnalyzer::new();
                let result = match analyzer.analyze_function(
                    &func.name, &func.file_path, &content,
                    func.start_line.saturating_sub(1), func.end_line
                ) {
                    Ok(r) => r,
                    Err(_) => continue,
                };

                for issue in result.unreachable_issues {
                    let severity_matches = match severity_filter {
                        "High" => issue.severity == Severity::High,
                        "Medium" => issue.severity == Severity::High || issue.severity == Severity::Medium,
                        _ => true,
                    };

                    if severity_matches && all_issues.len() < max_results {
                        all_issues.push(json!({
                            "function": func.name,
                            "file": func.file_path,
                            "line": issue.line_number,
                            "severity": issue.severity,
                            "reason": issue.reason,
                            "code": issue.code,
                        }));
                    }
                }
            }
        }

        let mut severity_counts = std::collections::HashMap::new();
        for issue in &all_issues {
            let severity = issue.get("severity").and_then(|s| s.as_str()).unwrap_or("Unknown");
            *severity_counts.entry(severity).or_insert(0) += 1;
        }

        let response = json!({
            "repo_id": repo_id,
            "total_functions_analyzed": functions.len(),
            "files_scanned": files_processed.len(),
            "total_issues_found": all_issues.len(),
            "severity_breakdown": severity_counts,
            "issues": &all_issues[..all_issues.len().min(max_results)],
            "summary": format!("Scanned {} functions across {} files: found {} issue(s)",
                functions.len(), files_processed.len(), all_issues.len())
        });

        Ok(serde_json::to_string_pretty(&response)?)
    }

    /// Run the MCP server
    pub async fn run(&mut self) -> Result<()> {
        info!("🚀 Starting Live Function Tree MCP Server...");
        info!("📡 Listening on stdin/stdout for MCP protocol messages");

        let stdin = tokio::io::stdin();
        let mut stdout = tokio::io::stdout();
        let mut reader = BufReader::new(stdin);
        let mut line = String::new();

        loop {
            line.clear();

            match reader.read_line(&mut line).await {
                Ok(0) => {
                    debug!("📥 EOF received, shutting down");
                    break;
                }
                Ok(_) => {
                    let trimmed = line.trim();
                    if trimmed.is_empty() {
                        continue;
                    }

                    info!("📨 Received from RooCode: {}", trimmed);

                    match serde_json::from_str::<JsonRpcRequest>(trimmed) {
                        Ok(request) => {
                            // Check if this is a notification (no id or id is null)
                            // JSON-RPC 2.0: Notifications MUST NOT have responses
                            let is_notification = request.id.is_none()
                                || request.id.as_ref().map(|v| v.is_null()).unwrap_or(false)
                                || request.method.starts_with("notifications/");

                            if is_notification {
                                // Process notification but don't send response
                                debug!("📭 Received notification: {} (no response needed)", request.method);
                                if let Err(e) = self.process_request(&request.method, &request).await {
                                    warn!("⚠️ Notification processing error (ignored): {}", e);
                                }
                                continue;
                            }

                            let response = match request.method.as_str() {
                                "initialize" => {
                                    match self.initialize(request.params).await {
                                        Ok(result) => JsonRpcResponse {
                                            jsonrpc: "2.0".to_string(),
                                            id: request.id,
                                            result: Some(result),
                                            error: None,
                                        },
                                        Err(e) => JsonRpcResponse {
                                            jsonrpc: "2.0".to_string(),
                                            id: request.id,
                                            result: None,
                                            error: Some(JsonRpcError {
                                                code: -32603,
                                                message: format!("Internal error: {}", e),
                                                data: None,
                                            }),
                                        }
                                    }
                                },
                                method => {
                                    match self.process_request(method, &request).await {
                                        Ok(result) => JsonRpcResponse {
                                            jsonrpc: "2.0".to_string(),
                                            id: request.id,
                                            result: Some(result),
                                            error: None,
                                        },
                                        Err(e) => JsonRpcResponse {
                                            jsonrpc: "2.0".to_string(),
                                            id: request.id,
                                            result: None,
                                            error: Some(JsonRpcError {
                                                code: -32603,
                                                message: format!("Internal error: {}", e),
                                                data: None,
                                            }),
                                        }
                                    }
                                }
                            };

                            let response_json = serde_json::to_string(&response)?;
                            debug!("📤 Sending: {}", response_json);
                            stdout.write_all(response_json.as_bytes()).await?;
                            stdout.write_all(b"\n").await?;
                            stdout.flush().await?;
                        }
                        Err(e) => {
                            error!("❌ Failed to parse JSON-RPC request: {}", e);
                            let error_response = JsonRpcResponse {
                                jsonrpc: "2.0".to_string(),
                                id: None,
                                result: None,
                                error: Some(JsonRpcError {
                                    code: -32700,
                                    message: "Parse error".to_string(),
                                    data: None,
                                }),
                            };
                            let response_json = serde_json::to_string(&error_response)?;
                            stdout.write_all(response_json.as_bytes()).await?;
                            stdout.write_all(b"\n").await?;
                            stdout.flush().await?;
                        }
                    }
                }
                Err(e) => {
                    error!("❌ Failed to read from stdin: {}", e);
                    break;
                }
            }
        }

        Ok(())
    }
