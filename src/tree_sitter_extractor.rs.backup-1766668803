    /// Calculate cyclomatic complexity from AST
    fn calculate_complexity_ast(&self, node: Node, language: SupportedLanguage) -> usize {
        let mut complexity = 1; // Base complexity

        let control_flow_types = match language {
            SupportedLanguage::Rust => vec![
                "if_expression", "match_expression", "while_expression",
                "for_expression", "loop_expression", "?",
            ],
            SupportedLanguage::Python => vec![
                "if_statement", "elif_clause", "while_statement",
                "for_statement", "try_statement", "except_clause",
                "with_statement", "match_statement",
            ],
            SupportedLanguage::JavaScript | SupportedLanguage::TypeScript => vec![
                "if_statement", "switch_statement", "while_statement",
                "for_statement", "for_in_statement", "do_statement",
                "ternary_expression", "catch_clause", "case",
            ],
            SupportedLanguage::Java => vec![
                "if_statement", "switch_expression", "while_statement",
                "for_statement", "enhanced_for_statement", "do_statement",
                "ternary_expression", "catch_clause", "case",
            ],
            SupportedLanguage::Go => vec![
                "if_statement", "switch_statement", "for_statement",
                "select_statement", "case_clause",
            ],
            SupportedLanguage::C | SupportedLanguage::Cpp => vec![
                "if_statement", "switch_statement", "while_statement",
                "for_statement", "do_statement", "conditional_expression",
                "case_statement",
            ],
            SupportedLanguage::Kotlin => vec![
                "if_expression", "when_expression", "while_statement",
                "for_statement", "do_while_statement", "try_expression",
                "catch_block", "when_entry",
            ],
            SupportedLanguage::Swift => vec![
                "if_statement", "switch_statement", "while_statement",
                "for_statement", "repeat_while_statement", "do_statement",
                "catch_clause", "case_item",
            ],
            SupportedLanguage::Ruby => vec![
                "if", "unless", "case", "while", "until",
                "for", "begin", "rescue", "when",
            ],
            SupportedLanguage::CSharp => vec![
                "if_statement", "switch_statement", "while_statement",
                "for_statement", "foreach_statement", "do_statement",
                "catch_clause", "switch_section",
            ],
            SupportedLanguage::Scala => vec![
                "if_expression", "match_expression", "while_expression",
                "for_expression", "try_expression", "catch_clause",
                "case_clause",
            ],
            SupportedLanguage::Bash => vec![
                "if_statement", "while_statement", "for_statement",
                "case_statement", "case_item",
            ],
        };

        fn count_control_flow(node: Node, types: &[&str]) -> usize {
            let mut count = 0;
            if types.contains(&node.kind()) {
                count += 1;
            }
            let mut cursor = node.walk();
            for child in node.children(&mut cursor) {
                count += count_control_flow(child, types);
            }
            count
        }

        complexity += count_control_flow(node, &control_flow_types);
        complexity
    }

    /// Extract docstring/comment before function
    fn extract_docstring(
        &self,
        node: Node,
        source: &[u8],
        source_str: &str,
        start_line: usize,
    ) -> Option<String> {
        if start_line <= 1 {
            return None;
        }

        let lines: Vec<&str> = source_str.lines().collect();
        let mut doc_lines = Vec::new();

        // Look at lines before the function
        for i in (0..start_line - 1).rev() {
            let line = lines.get(i)?.trim();
            if line.starts_with("///") || line.starts_with("//!") {
                doc_lines.insert(0, line.trim_start_matches('/').trim());
            } else if line.starts_with("#") && !line.starts_with("#[") {
                doc_lines.insert(0, line.trim_start_matches('#').trim());
            } else if line.starts_with("\"\"\"") || line.ends_with("\"\"\"") {
                doc_lines.insert(0, line.trim_matches('"').trim());
            } else if line.starts_with("/*") || line.starts_with("*") || line.ends_with("*/") {
                let clean = line.trim_start_matches("/*")
                    .trim_start_matches("*")
                    .trim_end_matches("*/")
                    .trim();
                if !clean.is_empty() {
                    doc_lines.insert(0, clean);
                }
            } else if !line.is_empty() && !line.starts_with("@") && !line.starts_with("#[") {
                break;
            }
        }

        if doc_lines.is_empty() {
            None
        } else {
            Some(doc_lines.join("\n"))
        }
    }

    /// Find nested functions within a function
    fn find_nested_functions(
        &self,
        node: Node,
        source: &[u8],
        language: SupportedLanguage,
    ) -> Vec<String> {
        let mut nested = Vec::new();
        let function_types = language.function_node_types();

        fn find_nested_recursive(
            node: Node,
            source: &[u8],
            types: &[&str],
            nested: &mut Vec<String>,
            depth: usize,
            extractor: &TreeSitterExtractor,
        ) {
            if depth > 0 && types.contains(&node.kind()) {
                // This is a nested function
                if let Some(name_node) = node.child_by_field_name("name") {
                    nested.push(extractor.node_text(name_node, source));
                }
            }

            let mut cursor = node.walk();
            for child in node.children(&mut cursor) {
                find_nested_recursive(child, source, types, nested, depth + 1, extractor);
            }
        }

        find_nested_recursive(node, source, function_types, &mut nested, 0, self);
        nested
    }

    /// Extract function parameters
    fn extract_parameters(
        &self,
        node: Node,
        source: &[u8],
        language: SupportedLanguage,
    ) -> Vec<Parameter> {
        let mut params = Vec::new();

        // Find parameters node
        let params_node = node.child_by_field_name("parameters")
            .or_else(|| node.child_by_field_name("formal_parameters"));

        if let Some(pn) = params_node {
            let mut cursor = pn.walk();
            for child in pn.children(&mut cursor) {
                match child.kind() {
                    "parameter" | "formal_parameter" | "required_parameter" |
                    "optional_parameter" | "typed_parameter" | "default_parameter" => {
                        let name = child.child_by_field_name("name")
                            .or_else(|| child.child_by_field_name("pattern"))
                            .map(|n| self.node_text(n, source))
                            .unwrap_or_else(|| self.node_text(child, source));

                        let param_type = child.child_by_field_name("type")
                            .map(|n| self.node_text(n, source));

                        let default_value = child.child_by_field_name("value")
                            .or_else(|| child.child_by_field_name("default_value"))
                            .map(|n| self.node_text(n, source));

                        let is_variadic = child.kind().contains("rest") ||
                            self.node_text(child, source).contains("...");

                        params.push(Parameter {
                            name,
                            param_type,
                            default_value,
                            is_variadic,
                        });
                    }
                    _ => {}
                }
            }
        }

        params
    }

    /// Extract return type
    fn extract_return_type(
        &self,
        node: Node,
        source: &[u8],
        language: SupportedLanguage,
    ) -> Option<String> {
        // Try different field names for return type
        node.child_by_field_name("return_type")
            .or_else(|| node.child_by_field_name("result"))
            .or_else(|| node.child_by_field_name("type"))
            .map(|n| self.node_text(n, source))
    }
}

impl Default for TreeSitterExtractor {
    fn default() -> Self {
        Self::new().expect("Failed to create TreeSitterExtractor")
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_python_extraction() {
        let mut extractor = TreeSitterExtractor::new().unwrap();
        let source = r#"
def hello(name: str) -> str:
    """Say hello to someone."""
    return f"Hello, {name}!"

async def fetch_data(url: str):
    async with session.get(url) as resp:
        return await resp.json()

class MyClass:
    def __init__(self):
        self.value = 0

    def increment(self):
        self.value += 1
"#;

        let functions = extractor.extract_functions(source, "test.py", SupportedLanguage::Python).unwrap();
        assert!(functions.len() >= 3);
        assert!(functions.iter().any(|f| f.name == "hello"));
        assert!(functions.iter().any(|f| f.name == "fetch_data" && f.is_async));
        assert!(functions.iter().any(|f| f.name == "MyClass"));
    }

