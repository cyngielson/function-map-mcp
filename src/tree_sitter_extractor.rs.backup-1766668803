    fn detect_visibility_from_text(&self, text: &str, lang: &str) -> Visibility {
        let first_line = text.lines().next().unwrap_or("");
        match lang {
            "php" | "csharp" | "java" => {
                if first_line.contains("private") { Visibility::Private }
                else if first_line.contains("protected") { Visibility::Protected }
                else if first_line.contains("internal") { Visibility::Internal }
                else if first_line.contains("public") { Visibility::Public }
                else { Visibility::Unknown }
            }
            _ => Visibility::Public
        }
    }

